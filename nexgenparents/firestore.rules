rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function getRole() {
      let userData = isSignedIn() ? getUserData(request.auth.uid) : null;
      return userData != null && userData.role != null ? userData.role : 'user';
    }

    function isAdmin() {
      return isSignedIn() && getRole() == 'admin';
    }

    function isModerator() {
      return isSignedIn() && getRole() in ['moderator', 'admin'];
    }

    // --- Coleccion: users ---
    match /users/{userId} {
      allow get: if isAdmin() || isOwner(userId);
      allow list: if isAdmin();

      // El usuario solo puede crear su propio perfil con rol basico.
      allow create: if isOwner(userId)
        && request.resource.data.role == 'user';

      // El usuario puede actualizar unicamente su propio perfil (sin rol).
      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys().isSubsetOf([
          'displayName', 'lastLogin', 'photoUrl', 'childrenBirthYears', 'ownedPlatforms', 'email'
        ]);

      // Solo admin puede cambiar el rol.
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role']);

      // Usuario elimina su propio perfil o admin elimina cualquiera.
      allow delete: if isOwner(userId) || isAdmin();
    }

    // --- Coleccion: dictionary_terms ---
    match /dictionary_terms/{termId} {
      // Lectura publica de terminos aprobados.
      allow get: if resource.data.status == 'approved'
        || (isSignedIn() && (resource.data.proposedBy == request.auth.uid || isModerator()));

      // Listado para usuarios autenticados.
      allow list: if isSignedIn();

      // Cualquier usuario autenticado puede proponer terminos en estado pending.
      allow create: if isSignedIn()
        && request.resource.data.proposedBy == request.auth.uid
        && request.resource.data.status == 'pending';

      // Cualquier usuario autenticado puede incrementar vistas de 1 en 1.
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount'])
        && request.resource.data.viewCount == resource.data.viewCount + 1;

      // Cualquier usuario autenticado puede votar de 1 en 1.
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes'])
        && request.resource.data.votes == resource.data.votes + 1;

      // Moderador/admin puede cambiar estado de moderacion.
      allow update: if isModerator()
        && request.resource.data.diff(resource.data).affectedKeys().isSubsetOf([
          'status', 'rejectionReason', 'approvedBy', 'updatedAt'
        ]);

      // Admin puede corregir contenido del termino.
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().isSubsetOf([
          'term', 'definition', 'example', 'category', 'updatedAt'
        ]);

      // Solo admin elimina terminos.
      allow delete: if isAdmin();
    }

    // --- Coleccion: parental_guides_extra ---
    match /parental_guides_extra/{guideId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
