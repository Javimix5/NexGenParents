rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========== HELPER FUNCTIONS ==========
    function coreTermFieldsUnchanged(existing, incoming) {
      return incoming.term == existing.term &&
             incoming.definition == existing.definition &&
             incoming.example == existing.example &&
             incoming.category == existing.category &&
             incoming.status == existing.status &&
             incoming.proposedBy == existing.proposedBy &&
             incoming.approvedBy == existing.approvedBy &&
             incoming.rejectionReason == existing.rejectionReason &&
             incoming.createdAt == existing.createdAt;
    }

    function isModeratorOrAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['moderator', 'admin'];
    }

    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ========== USER PROFILES ==========
    match /users/{userId} {
      // A user can create their own document upon signup.
      allow create: if request.auth != null && request.auth.uid == userId;

      // A user can read their own document. Admins can read any user document.
      allow get: if request.auth != null && (request.auth.uid == userId || isAdmin());
      
      // Admins can list all users.
      allow list: if request.auth != null && isAdmin();

      // A user can update their own document but cannot change their role.
      // Admins can update any user's document.
      allow update: if request.auth != null && 
        (
          (request.auth.uid == userId && request.resource.data.role == resource.data.role) || 
          isAdmin()
        );
        
      // A user can delete their own account document.
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ========== DICTIONARY TERMS ==========
    match /dictionary_terms/{termId} {
      // Anyone can read approved terms.
      // Authenticated users can read their own proposals.
      // Moderators/Admins can read any term.
      allow read: if resource.data.status == 'approved' ||
                 (request.auth != null && request.auth.uid == resource.data.proposedBy) ||
                 (request.auth != null && isModeratorOrAdmin());

      // Any authenticated user can propose a new term.
      // We must validate the incoming data for security.
      allow create: if request.auth != null &&
                      request.resource.data.proposedBy == request.auth.uid &&
                      request.resource.data.status == 'pending' &&
                      request.resource.data.term is string &&
                      request.resource.data.definition is string;

      // Users can update their own proposals if not yet approved.
      // Moderators/Admins can update any term (e.g., to approve/reject it).
      // Any authenticated user can vote or increment view count.
      allow update: if request.auth != null && 
        (
          (request.auth.uid == resource.data.proposedBy && resource.data.status != 'approved') ||
          isModeratorOrAdmin() ||
          // Allow voting or incrementing view count on approved terms
          (
            resource.data.status == 'approved' &&
            coreTermFieldsUnchanged(resource.data, request.resource.data) &&
            (
              // Is voting: votes increments, viewCount is unchanged
              (
                request.resource.data.votes == (resource.data.votes == null ? 1 : resource.data.votes + 1) &&
                request.resource.data.viewCount == resource.data.viewCount
              ) ||
              // Is viewing: viewCount increments, votes is unchanged
              (
                request.resource.data.viewCount == (resource.data.viewCount == null ? 1 : resource.data.viewCount + 1) &&
                request.resource.data.votes == resource.data.votes
              )
            )
          )
        );

      // Only admins can delete terms.
      allow delete: if request.auth != null && isAdmin();
    }
    
    // ========== PARENTAL GUIDES ==========
    match /parental_guides_extra/{guideId} {
      // This content is public and read-only for all users.
      allow read: if true;
    }
  }
}
